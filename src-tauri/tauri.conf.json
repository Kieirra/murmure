{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "murmure",
    "version": "1.9.0",
    "identifier": "com.al1x-ai.murmure",
    "build": {
        "beforeDevCommand": "pnpm dev",
        "devUrl": "http://localhost:1420",
        "beforeBuildCommand": "pnpm build",
        "frontendDist": "../dist"
    },
    "app": {
        "windows": [
            {
                "title": "Murmure",
                "width": 920,
                "height": 768,
                "minWidth": 870,
                "minHeight": 720
            }
        ],
        "security": {
            "csp": null
        },
        "macOSPrivateApi": true
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/64x64.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/256x256.png",
            "icons/icon.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "resources": ["../resources/**/*", "resources/smartmic/*"],
        "macOS": {
            "entitlements": "./Entitlements.plist"
        },
        "linux": {
            "appimage": {
                "files": {
                    "/usr/share/README.md": "../README.md",
                    "/usr/resources": "../resources/"
                }
            },
            "deb": {
                "recommends": [
                    "wl-clipboard",
                    "libgtk-layer-shell0"
                ],
                "files": {
                    "/usr/lib/udev/rules.d/60-murmure-uinput.rules": "../packaging/linux/60-murmure-uinput.rules"
                },
                "postInstallScript": "../packaging/linux/postinst",
                "preRemoveScript": "../packaging/linux/prerm",
                "postRemoveScript": "../packaging/linux/postrm"
            },
            "rpm": {
                "depends": [
                    "webkit2gtk4.1",
                    "libayatana-appindicator-gtk3",
                    "openssl-libs",
                    "pipewire-pulseaudio",
                    "pipewire-utils",
                    "xdg-desktop-portal"
                ],
                "recommends": [
                    "gtk-layer-shell",
                    "wl-clipboard"
                ],
                "files": {
                    "/usr/lib/udev/rules.d/60-murmure-uinput.rules": "../packaging/linux/60-murmure-uinput.rules"
                },
                "postInstallScript": "../packaging/linux/postinst",
                "postRemoveScript": "../packaging/linux/postrm",
                "compression": {
                    "type": "none"
                }
            }
        },
        "windows": {
            "nsis": {
                "installMode": "currentUser"
            }
        }
    },
    "plugins": {
        "updater": {
            "active": true,
            "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDNDRTZFRDczMzY2MzI5NDEKUldSQktXTTJjKzNtUEl6Q2htQ1AvcXlWVzExOG5wYWtLUjFYWVFWUCtnQU9Qb1o3RG03VmwzakkK",
            "endpoints": ["https://github.com/Kieirra/murmure/releases/latest/download/latest.json"],
            "windows": {
                "installMode": "passive"
            }
        }
    }
}
