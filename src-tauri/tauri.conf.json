{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "murmure",
    "version": "1.8.1",
    "identifier": "com.al1x-ai.murmure",
    "build": {
        "beforeDevCommand": "pnpm dev",
        "devUrl": "http://localhost:1420",
        "beforeBuildCommand": "pnpm build",
        "frontendDist": "../dist"
    },
    "app": {
        "windows": [
            {
                "title": "Murmure",
                "width": 920,
                "height": 768,
                "minWidth": 870,
                "minHeight": 720
            }
        ],
        "security": {
            "csp": null
        },
        "macOSPrivateApi": true
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/64x64.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/256x256.png",
            "icons/icon.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "resources": ["../resources/**/*", "resources/smartmic/*"],
        "macOS": {
            "entitlements": "./Entitlements.plist"
        },
        "linux": {
            "appimage": {
                "files": {
                    "/usr/share/README.md": "../README.md",
                    "/usr/resources": "../resources/"
                }
            },
            "deb": {
                "postInstallScript": "../packaging/linux/postinst",
                "preRemoveScript": "../packaging/linux/prerm"
            }
        },
        "windows": {
            "nsis": {
                "installMode": "currentUser"
            }
        }
    },
    "plugins": {
        "cli": {
            "description": "Murmure - Privacy-first speech-to-text",
            "args": [
                {
                    "name": "transcription",
                    "description": "Toggle standard transcription on/off"
                },
                {
                    "name": "transcription-llm",
                    "description": "Toggle transcription in LLM mode"
                },
                {
                    "name": "transcription-command",
                    "description": "Toggle transcription in command mode"
                },
                {
                    "name": "paste-last",
                    "description": "Paste the last transcription"
                },
                {
                    "name": "cancel",
                    "description": "Cancel the current recording"
                },
                {
                    "name": "voice-mode",
                    "description": "Toggle Voice Mode on/off"
                },
                {
                    "name": "llm-mode",
                    "takesValue": true,
                    "description": "Switch to LLM mode N (1-4)"
                }
            ],
            "subcommands": {
                "import": {
                    "description": "Import a .murmure configuration file",
                    "args": [
                        {
                            "name": "file",
                            "index": 1,
                            "takesValue": true,
                            "required": true,
                            "description": "Path to the .murmure file to import"
                        },
                        {
                            "name": "strategy",
                            "short": "s",
                            "takesValue": true,
                            "description": "Import strategy: replace (default) or merge"
                        }
                    ]
                }
            }
        },
        "updater": {
            "active": true,
            "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDNDRTZFRDczMzY2MzI5NDEKUldSQktXTTJjKzNtUEl6Q2htQ1AvcXlWVzExOG5wYWtLUjFYWVFWUCtnQU9Qb1o3RG03VmwzakkK",
            "endpoints": ["https://github.com/Kieirra/murmure/releases/latest/download/latest.json"],
            "windows": {
                "installMode": "passive"
            }
        }
    }
}
