{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "noImplicitAny": true,
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "types": ["node", "mocha", "@wdio/globals/types"],
        "lib": ["ES2022", "DOM"]
    },
    "include": ["wdio.conf.ts", "specs/**/*.ts"]
}
